# ============================================================
# 2MC Gastro — environment variables (example)
# Copy to .env and fill in. Never commit .env to git.
# ============================================================

# --- Supabase ------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Stripe (client) ----------------------------------------
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# --- PostHog (client, analytics) ----------------------------
VITE_POSTHOG_KEY=phc_your_posthog_project_key
VITE_POSTHOG_HOST=https://eu.posthog.com

# --- Meilisearch (client, search-only key) ------------------
VITE_MEILI_HOST=https://search.2mcgastro.com
VITE_MEILI_SEARCH_KEY=your-search-only-key

# --- App ----------------------------------------------------
APP_URL=http://localhost:5173

# ============================================================
# Server-side only — set these as Supabase edge function
# secrets with `supabase secrets set KEY=value` or via dashboard.
# DO NOT prefix with VITE_ — they must never be exposed.
# ============================================================

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Resend (transactional email)
RESEND_API_KEY=re_your_resend_key
RESEND_FROM=2MC Gastro <noreply@2mcgastro.com>

# Meilisearch (admin key — sync only)
MEILI_HOST=https://search.2mcgastro.com
MEILI_ADMIN_KEY=your-admin-key

# Anthropic Claude (AI chat)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Legacy — Meshy AI (3D generation, already used)
MESHY_API_KEY=your-meshy-key

# Legacy — Gemini (optional)
GEMINI_API_KEY=your-gemini-key
