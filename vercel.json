{
  "functions": {
    "api/sync-diamond.ts": {
      "maxDuration": 300
    },
    "api/sync-combisteel.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/sync-diamond",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/sync-combisteel",
      "schedule": "0 6 * * *"
    }
  ]
}
